#!/usr/bin/env bash
# sg — smart grep for AI coding agents
# Auto-routes: ayg (n-gram indexed, 8-460x faster) → rg (fallback)
#
# Attribution:
#   ayg/aygrep — https://github.com/hemeda3/aygrep  (sparse n-gram indexed search)
#   ripgrep    — https://github.com/BurntSushi/ripgrep
#   ast-grep   — https://github.com/ast-grep/ast-grep (structural, use `ast-grep` directly)
#
# NOTE on "seek" BM25 tool:
#   dualeai/seek wraps zoekt (Go, 33 stars, not on crates.io) — install manually if needed.
#   The `seek` on crates.io is yxshv/seek (app launcher — WRONG TOOL).
#   For symbol/structural search: use `ast-grep -p 'pattern'` instead.
#   For BM25 ranking: zoekt (https://github.com/sourcegraph/zoekt) — complex self-hosted setup.
#
# Benchmarks vs ripgrep (warm, indexed):
#   Small repo (<10k files):    rg  ~20ms  |  ayg requires build first
#   Medium repo (10k-100k):     rg ~500ms  |  ayg ~60ms  (8x faster)
#   Large repo (100k+ files):   rg ~29s    |  ayg ~60ms  (460x faster)
#   Linux kernel (40M lines):   rg ~1.5s   |  ayg ~6ms   (hot, 250x faster)
#
# For structural/symbol search: use ast-grep directly
#   ast-grep -p 'async function $F($_) { $$$ }'   # match any async function
#   ast-grep -p 'console.log($ARG)'               # match all console.log calls
#
# Routing logic:
#   ayg_index/ exists in repo root → use ayg (indexed mode)
#   else if file count > 5000      → suggest: sg build . first
#   else                           → use rg (fast enough, no index needed)
#
# Claude Code note: for Claude Code sessions, prefer native Grep tool (MCP)
# for files already in context. Use sg for large codebase searches.
#
# Usage:
#   sg <pattern> [path]           — auto-route
#   sg <pattern> [path] --force-ayg   — always use ayg (requires index)
#   sg <pattern> [path] --force-rg    — always use rg
#   sg build [path]               — build ayg index (run once per repo)
#   sg stats                      — show index status

set -euo pipefail

AYG=$(command -v ayg 2>/dev/null || echo "")
RG=$(command -v rg 2>/dev/null || echo "")

usage() {
  cat <<EOF
sg — smart grep (ayg + ripgrep auto-router)

Usage:
  sg <pattern> [path]       Auto-route based on repo size / index
  sg build [path]           Build ayg index (one-time, ~30s for large repos)
  sg stats                  Show index status and routing decision
  sg <pattern> --force-ayg  Force indexed search
  sg <pattern> --force-rg   Force ripgrep

Options:
  -l, --files       List matching files only
  -c, --count       Show match count only
  -n, --line-nums   Show line numbers (default on)
  --json            JSON output for scripts
  -i, --ignore-case Case-insensitive

Structural search (syntax-aware):
  ast-grep -p 'pattern'     AST pattern matching (install: brew install ast-grep)
  ast-grep -p 'async \$F(\$_)'  match any async function

Archive/PDF search:
  rga "term" .              Search PDFs, Office, zip, epub (install: brew install ripgrep-all)
EOF
  exit 0
}

PATTERN=""
SEARCH_PATH="."
FORCE_AYG=0
FORCE_RG=0
AYG_OPTS=""
RG_OPTS="-n"
SUB=""

for arg in "$@"; do
  case "$arg" in
    build)       SUB="build"; shift 2>/dev/null || true; SEARCH_PATH="${1:-.}"; break ;;
    stats)       SUB="stats"; break ;;
    --force-ayg) FORCE_AYG=1 ;;
    --force-rg)  FORCE_RG=1 ;;
    -l|--files)  AYG_OPTS="$AYG_OPTS -l"; RG_OPTS="$RG_OPTS -l" ;;
    -c|--count)  AYG_OPTS="$AYG_OPTS -c"; RG_OPTS="$RG_OPTS -c" ;;
    -i|--ignore-case) AYG_OPTS="$AYG_OPTS -i"; RG_OPTS="$RG_OPTS -i" ;;
    --json)      AYG_OPTS="$AYG_OPTS --json"; RG_OPTS="$RG_OPTS --json" ;;
    -h|--help)   usage ;;
    -*)          RG_OPTS="$RG_OPTS $arg" ;;
    *)
      if [[ -z "$PATTERN" ]]; then PATTERN="$arg"
      else SEARCH_PATH="$arg"
      fi ;;
  esac
done

# Subcommands
if [[ "$SUB" == "build" ]]; then
  if [[ -z "$AYG" ]]; then
    echo "[sg] ayg not installed. Install: brew install hemeda3/tap/ayg" >&2
    exit 1
  fi
  echo "[sg] Building ayg index for: ${SEARCH_PATH}..."
  time "$AYG" build "$SEARCH_PATH"
  echo "[sg] Index built. Use: sg <pattern>"
  exit 0
fi

if [[ "$SUB" == "stats" ]]; then
  path="${1:-.}"
  if [[ -d "$path/ayg_index" ]]; then
    SIZE=$(du -sh "$path/ayg_index" 2>/dev/null | cut -f1)
    FILES=$(find "$path" -type f 2>/dev/null | wc -l | tr -d ' ')
    echo "[sg] ayg index: FOUND ($SIZE) | files: $FILES → will use ayg (fast path)"
  else
    FILES=$(find "${path:-.}" -type f 2>/dev/null | wc -l | tr -d ' ')
    echo "[sg] ayg index: NOT FOUND | files: $FILES"
    if [[ $FILES -gt 5000 ]]; then
      echo "[sg] RECOMMENDATION: run 'sg build .' — repo is large enough to benefit"
      echo "[sg] Expected speedup: ~100x vs ripgrep for this repo size"
    else
      echo "[sg] routing: ripgrep (repo small enough)"
    fi
  fi
  echo "[sg] Structural search: ast-grep -p 'pattern'  (brew install ast-grep)"
  echo "[sg] Archive search:    rga 'term'              (brew install ripgrep-all)"
  exit 0
fi

[[ -z "$PATTERN" ]] && usage

# Routing decision
use_ayg() {
  [[ $FORCE_RG -eq 1 ]] && return 1
  [[ -z "$AYG" ]] && return 1
  [[ $FORCE_AYG -eq 1 ]] && return 0
  local idx_path="${SEARCH_PATH}/ayg_index"
  [[ ! -d "$idx_path" ]] && idx_path="./ayg_index"
  [[ -d "$idx_path" ]]
}

if use_ayg; then
  if [[ -d "./ayg_index" ]]; then
    exec "$AYG" search "$PATTERN" $AYG_OPTS
  elif [[ -d "${SEARCH_PATH}/ayg_index" ]]; then
    cd "$SEARCH_PATH"
    exec "$AYG" search "$PATTERN" $AYG_OPTS
  fi
fi

# Fallback: ripgrep
if [[ -n "$RG" ]]; then
  exec "$RG" $RG_OPTS "$PATTERN" "$SEARCH_PATH"
else
  exec grep -rn "$PATTERN" "$SEARCH_PATH"
fi
