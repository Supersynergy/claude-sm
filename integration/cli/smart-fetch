#!/usr/bin/env python3
"""
smart-fetch — fused web fetch tool for AI coding agents.
Combines: curl_cffi (stealth) + trafilatura (HTML extraction) + rtk curl (JSON/API)
Auto-routes by URL type. No Gemma/LLM needed for most cases.

Attribution:
  curl_cffi    — https://github.com/yifeikong/curl_cffi  (Chrome fingerprint impersonation)
  trafilatura  — https://github.com/adbar/trafilatura    (HTML→text, no LLM)
  rtk          — https://github.com/rtk-ai/rtk           (JSON schema extraction)
  ayg/aygrep   — https://github.com/hemeda3/aygrep       (fast indexed code search)

Usage:
  smart-fetch <url> [--mode auto|json|html|schema|raw] [--extract "field"] [--no-cache]

Output: single-line JSON  {"url":..,"tokens":..,"mode":..,"content":..}

Benchmarks (2026-04-15):
  raw curl /json:     107t, 814ms
  rtk curl /json:      39t, 890ms  (-63%)
  curl_cffi+keys:       3t,1302ms  (-97%)
  raw HTML page:   12500t, 800ms
  +trafilatura:     1250t, 800ms  (-90%, 0 LLM)
  hyperfetch+gemma:  125t,2700ms  (-99%, 2.7s)

Routing:
  API/JSON endpoint  → curl_cffi + json.keys() extract        = 3-39t
  HTML article/doc   → curl_cffi + trafilatura                = ~200-1250t
  HTML + extract     → curl_cffi + trafilatura + field grep   = 5-50t
  Anti-bot target    → curl_cffi impersonate=chrome           = auto
  schema only        → rtk curl --schema (if rtk available)   = ~15t
"""

import sys
import json
import os
import re
import subprocess
import time
import argparse
from urllib.parse import urlparse

def eprint(*a): print(*a, file=sys.stderr)

def is_api_endpoint(url: str) -> bool:
    """Heuristic: small structured JSON endpoint, not a full HTML page."""
    path = urlparse(url).path.lower()
    api_patterns = [
        r'/api/', r'/v\d+/', r'\.json$', r'/json$', r'/get$', r'/post$',
        r'/status/', r'/health', r'/ping', r'/metrics', r'/graphql',
        r'/rest/', r'/rpc', r'\.xml$',
    ]
    return any(re.search(p, path) for p in api_patterns)

def fetch_curl_cffi(url: str, impersonate: str = 'chrome110') -> tuple[str, int]:
    """Fetch via curl_cffi — stealth Chrome fingerprint, bypasses most bot detection."""
    try:
        import curl_cffi.requests as req
        t0 = time.perf_counter()
        r = req.get(url, impersonate=impersonate, timeout=15)
        ms = int((time.perf_counter() - t0) * 1000)
        return r.text, ms
    except ImportError:
        # Fallback: system curl
        t0 = time.perf_counter()
        r = subprocess.run(['curl', '-sL', '--max-time', '15', url],
                           capture_output=True, text=True)
        ms = int((time.perf_counter() - t0) * 1000)
        return r.stdout, ms

def extract_json_compact(text: str, extract_field: str = '') -> str:
    """JSON → compact keys or specific field. 3-39 tokens vs 107 raw."""
    try:
        d = json.loads(text)
        if extract_field:
            # Try to find the field at any depth
            def find(obj, key):
                if isinstance(obj, dict):
                    if key in obj: return obj[key]
                    for v in obj.values():
                        r = find(v, key)
                        if r is not None: return r
                elif isinstance(obj, list):
                    for item in obj:
                        r = find(item, key)
                        if r is not None: return r
                return None
            val = find(d, extract_field)
            return json.dumps({extract_field: val}) if val is not None else json.dumps(list(d.keys()) if isinstance(d, dict) else d)
        # Default: keys + value types only (schema)
        if isinstance(d, dict):
            schema = {k: type(v).__name__ for k, v in d.items()}
            return json.dumps(schema)
        elif isinstance(d, list) and d:
            return json.dumps({'list_length': len(d), 'item_keys': list(d[0].keys()) if isinstance(d[0], dict) else type(d[0]).__name__})
        return json.dumps(d)
    except (json.JSONDecodeError, Exception):
        return text[:500]

def extract_html_trafilatura(html: str, extract_field: str = '') -> str:
    """HTML → clean text via trafilatura (no LLM). ~10x smaller than raw HTML."""
    try:
        import trafilatura
        text = trafilatura.extract(html, include_comments=False,
                                   include_tables=True, no_fallback=False) or ''
        if extract_field and text:
            # Find lines containing the field
            hits = [l.strip() for l in text.splitlines()
                    if extract_field.lower() in l.lower()]
            return '\n'.join(hits[:5]) if hits else text[:1000]
        return text[:4000] if text else html_fallback(html)
    except ImportError:
        return html_fallback(html)

def html_fallback(html: str) -> str:
    """Strip tags with regex — fast, no deps."""
    # Remove script/style blocks
    html = re.sub(r'<(script|style|nav|footer|header)[^>]*>.*?</\1>', '', html, flags=re.DOTALL|re.I)
    text = re.sub(r'<[^>]+>', ' ', html)
    text = re.sub(r'\s+', ' ', text).strip()
    return text[:2000]

def estimate_tokens(text: str) -> int:
    return max(1, len(text) // 4)

def main():
    parser = argparse.ArgumentParser(description='smart-fetch: fused token-efficient web fetch')
    parser.add_argument('url', help='URL to fetch')
    parser.add_argument('--mode', default='auto',
                        choices=['auto','json','html','schema','raw'],
                        help='Force fetch mode (default: auto-detect)')
    parser.add_argument('--extract', default='', help='Extract specific field/keyword')
    parser.add_argument('--no-cache', action='store_true', help='Skip cache')
    parser.add_argument('--impersonate', default='chrome110',
                        help='curl_cffi impersonation target (default: chrome110)')
    args = parser.parse_args()

    url = args.url
    t_total = time.perf_counter()

    # Fetch
    body, fetch_ms = fetch_curl_cffi(url, args.impersonate)

    # Auto-detect mode
    mode = args.mode
    if mode == 'auto':
        content_type_hint = body[:200].strip().lower()
        if is_api_endpoint(url) or content_type_hint.startswith('{') or content_type_hint.startswith('['):
            mode = 'json'
        elif '<html' in content_type_hint or '<!doctype' in content_type_hint:
            mode = 'html'
        else:
            mode = 'raw'

    # Process
    if mode == 'json' or mode == 'schema':
        content = extract_json_compact(body, args.extract)
        mode_used = 'json+extract' if args.extract else 'json+schema'
    elif mode == 'html':
        content = extract_html_trafilatura(body, args.extract)
        mode_used = 'html+trafilatura' + ('+extract' if args.extract else '')
    else:
        content = body[:2000]
        mode_used = 'raw'

    total_ms = int((time.perf_counter() - t_total) * 1000)
    tokens = estimate_tokens(content)
    raw_tokens = estimate_tokens(body)
    savings_pct = round((1 - tokens / raw_tokens) * 100) if raw_tokens > 0 else 0

    result = {
        'url': url,
        'mode': mode_used,
        'tokens': tokens,
        'raw_tokens': raw_tokens,
        'savings_pct': savings_pct,
        'fetch_ms': fetch_ms,
        'total_ms': total_ms,
        'content': content,
    }
    print(json.dumps(result))

if __name__ == '__main__':
    main()
